# Maintainer: Carlos David Isturiz <light.log at proton dot me>

pkgname=warp-control
pkgver=2.0.0
pkgrel=1
pkgdesc='GTK desktop control panel for Cloudflare WARP (experimental on Arch)'
arch=('any')
url='https://github.com/Light-log/warp-control-fedora'
license=('MIT')
depends=(
  'python'
  'python-gobject'
  'gtk3'
  'libayatana-appindicator'
  'python-idna'
)
makedepends=(
  'python-build'
  'python-installer'
  'python-setuptools'
  'python-wheel'
)
checkdepends=(
  'python-pytest'
  'python-yaml'
)

# Arch users provide warp-cli separately; this package never installs WARP itself.
source=("$pkgname-$pkgver.tar.gz::$url/releases/download/v$pkgver/$pkgname-$pkgver.tar.gz")
sha256sums=('d35afa240c7d365d82b66008810949ba45a957994978a35a9e78b7482ed774e4')

build() {
  cd "$srcdir/$pkgname-$pkgver"
  python -m build --wheel --no-isolation
}

check() {
  cd "$srcdir/$pkgname-$pkgver"
  python -m pytest -m 'not ui' \
    tests/test_*.py tests/installers tests/services tests/ui
}

package() {
  cd "$srcdir/$pkgname-$pkgver"
  python -m installer --destdir="$pkgdir" dist/*.whl

  install -Dm644 data/com.devruby.warpcontrol.desktop \
    "$pkgdir/usr/share/applications/com.devruby.warpcontrol.desktop"
  install -Dm644 data/com.devruby.warpcontrol.metainfo.xml \
    "$pkgdir/usr/share/metainfo/com.devruby.warpcontrol.metainfo.xml"
  install -Dm644 data/icons/com.devruby.warpcontrol.svg \
    "$pkgdir/usr/share/icons/hicolor/scalable/apps/com.devruby.warpcontrol.svg"
  install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
  install -Dm644 README.md "$pkgdir/usr/share/doc/$pkgname/README.md"
}
